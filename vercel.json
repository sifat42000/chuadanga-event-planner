{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/www/:path*",
      "destination": "https://chuadangaeventplanner.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "destination": "https://chuadangaeventplanner.com/:path*",
      "has": [
        { "type": "host", "value": "chuadanga-event-planner.vercel.app" }
      ],
      "permanent": true
    }
  ]
}