{
  "redirects": [
    {
      "source": "/www/:path*",
      "destination": "https://chuadangaeventplanner.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "chuadanga-event-planner.vercel.app"
        }
      ],
      "destination": "https://chuadangaeventplanner.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}